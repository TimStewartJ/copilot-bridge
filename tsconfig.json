{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": [
    "src/shared/**/*",
    "src/server/**/*",
    "src/launcher.ts",
    "src/launcher-*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/client"]
}
