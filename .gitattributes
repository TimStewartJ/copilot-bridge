# Normalize text files to LF so Windows and Linux checkouts do not churn line endings.
* text=auto eol=lf

# Windows command scripts need CRLF when they are added later.
*.bat text eol=crlf
*.cmd text eol=crlf

# Keep common binary assets out of text normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.7z binary
