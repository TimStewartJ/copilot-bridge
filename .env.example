# Copilot Bridge — Environment Configuration
# Copy to .env and fill in values.

# (Optional) Webhook URL for status notifications (server start, restart, tunnel ready)
# Supports any webhook that accepts POST with JSON body: { "message": "...", "url": "..." }
# Examples: Power Automate, Slack incoming webhook, Discord webhook, etc.
BRIDGE_WEBHOOK_URL=

# (Optional) Override the auto-discovered dev tunnel URL
# Only needed if tunnel URL detection doesn't work automatically
BRIDGE_TUNNEL_URL=

# (Optional) Canonical externally reachable base URL for the bridge.
# Used for staging preview links and startup notifications in non-dev-tunnel deployments.
# Example: https://bridge.example.com or https://example.com/bridge
BRIDGE_PUBLIC_BASE_URL=

# (Optional) Trust X-Forwarded-* headers when learning a public URL from incoming requests.
# Enable this when the bridge is behind a trusted reverse proxy or tunnel that forwards host/proto.
BRIDGE_TRUST_PROXY=

# (Optional) Dev tunnel name override (default: copilot-bridge)
BRIDGE_TUNNEL_NAME=
