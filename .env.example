# Copilot Bridge — Environment Configuration
# Copy to .env and fill in values.

# (Optional) Webhook URL for status notifications (server start, restart, tunnel ready)
# Supports any webhook that accepts POST with JSON body: { "message": "...", "url": "..." }
# Examples: Power Automate, Slack incoming webhook, Discord webhook, etc.
BRIDGE_WEBHOOK_URL=

# (Optional) Override the auto-discovered dev tunnel URL
# Only needed if tunnel URL detection doesn't work automatically
BRIDGE_TUNNEL_URL=

# (Optional) Dev tunnel name override (default: copilot-bridge)
BRIDGE_TUNNEL_NAME=
