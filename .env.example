# Copilot Bridge — Environment Configuration
# Copy to .env and fill in values.
# The launcher and direct server entrypoint load this file automatically at startup.

# (Optional) Webhook URL for status notifications (server start, restart, tunnel ready)
# Supports any webhook that accepts POST with JSON body: { "message": "...", "url": "..." }
# Examples: Power Automate, Slack incoming webhook, Discord webhook, etc.
BRIDGE_WEBHOOK_URL=

# (Optional) Local app port for the bridge server (default: 3333)
# Restart the launcher/server after changing this value.
BRIDGE_PORT=

# (Optional) Dedicated token for Copilot SDK auth.
# If set, Bridge passes this token directly to the SDK and disables stored/gh fallback.
# If empty, the SDK uses its default auth discovery, including gh as a fallback.
BRIDGE_COPILOT_GITHUB_TOKEN=

# (Optional) Runtime distribution mode.
# development: repo checkout with git-backed startup, self-update, staging, and rollback.
# release: packaged app mode with no git requirement and user data outside the app.
# If omitted, the bridge uses development mode when .git exists and release mode otherwise.
BRIDGE_DISTRIBUTION_MODE=

# (Optional) Durable user data locations. Release installs should keep these outside the app folder.
# In release mode, BRIDGE_DATA_DIR defaults to the per-user CopilotBridge data folder.
BRIDGE_DATA_DIR=
BRIDGE_DOCS_DIR=

# (Optional) Override the auto-discovered dev tunnel URL
# Only needed if tunnel URL detection doesn't work automatically
BRIDGE_TUNNEL_URL=

# (Optional) Canonical externally reachable base URL for the bridge.
# Used for staging preview links and startup notifications in non-dev-tunnel deployments.
# Example: https://bridge.example.com or https://example.com/bridge
BRIDGE_PUBLIC_BASE_URL=

# (Optional) Trust X-Forwarded-* headers when learning a public URL from incoming requests.
# Enable this when the bridge is behind a trusted reverse proxy or tunnel that forwards host/proto.
BRIDGE_TRUST_PROXY=

# (Optional) Dev tunnel name override (default: copilot-bridge)
BRIDGE_TUNNEL_NAME=

# (Optional) Enable the Copilot CLI computer-use MCP server.
# Provides desktop automation tools: mouse, keyboard, screenshots, clipboard.
# Requires native bindings (prebuilt for linux-x64, linux-arm64, darwin-arm64, win32-x64, win32-arm64).
# ⚠️  WARNING: Enables full unattended desktop automation. The bridge auto-approves
# access requests so the agent can control mouse, keyboard, and clipboard without
# manual confirmation. Only enable on a trusted, local/private bridge.
COMPUTER_USE=

# (Optional) Enable server-side voice transcription with whisper.cpp.
# Configure these on the host, then restart the Bridge.
# BRIDGE_WHISPER_CPP_ARGS_JSON should be a JSON array of extra CLI args.
BRIDGE_TRANSCRIPTION_PROVIDER=
BRIDGE_TRANSCRIPTION_MAX_DURATION_SECONDS=
BRIDGE_TRANSCRIPTION_TIMEOUT_MS=
BRIDGE_WHISPER_CPP_COMMAND=
BRIDGE_WHISPER_CPP_MODEL=
BRIDGE_WHISPER_CPP_LANGUAGE=
BRIDGE_WHISPER_CPP_ARGS_JSON=
BRIDGE_WHISPER_CPP_NO_GPU=
