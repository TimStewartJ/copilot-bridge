{
  "name": "copilot-bridge",
  "version": "0.1.0",
  "description": "Personal work dashboard powered by Copilot SDK + MCP",
  "author": "Tim Stewart <timstewartj@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/timstewartj/copilot-bridge.git"
  },
  "homepage": "https://github.com/timstewartj/copilot-bridge#readme",
  "type": "module",
  "scripts": {
    "dev": "npx tsx src/launcher.ts",
    "dev:server": "npx tsx src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "typecheck:server": "tsc --noEmit -p tsconfig.json",
    "typecheck:server:ts7-preview": "tsgo --noEmit -p tsconfig.json",
    "typecheck:client": "tsx src/server/client-typecheck-baseline.ts",
    "typecheck:client:update-baseline": "tsx src/server/client-typecheck-baseline.ts --write-baseline",
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:client": "vitest run --config vitest.client.config.ts",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:launcher": "vitest run --config vitest.launcher.config.ts",
    "test:staging": "vitest run --config vitest.staging.config.ts",
    "test:lanes": "npm run test:client && npm run test:server && npm run test:launcher && npm run test:staging",
    "test:slow-report": "vitest run --reporter=json --outputFile=.vitest-slowest.json && tsx src/server/slow-test-report.ts .vitest-slowest.json",
    "test:xplat-audit": "tsx src/server/xplat-test-audit.ts",
    "check:fast": "npm run test:xplat-audit && npm run typecheck",
    "check:client": "npm run typecheck:client && npm run test:client",
    "check:server": "npm run typecheck:server && npm run test:server",
    "check:launcher": "npm run typecheck:server && npm run test:launcher",
    "check:staging": "npm run typecheck:server && npm run test:staging",
    "check:pr": "npm run check:fast && npm run test:lanes && npm run build",
    "check:experimental": "npm run typecheck:server:ts7-preview",
    "check:deploy": "tsx src/server/deploy-check.ts",
    "check:deploy:staging": "npm run check:pr && npm run preview:smoke",
    "test:preview": "npm run check:fast && npm run test:lanes",
    "test:deploy": "npm run check:pr",
    "test:coverage": "vitest run --coverage",
    "test:full": "npm run check:deploy",
    "preview:smoke": "tsx src/server/preview-smoke.ts",
    "preview:smoke:full": "tsx src/server/preview-smoke.ts --validate",
    "postinstall": "patch-package --error-on-fail"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@github/copilot-sdk": "1.0.0-beta.8",
    "@tanstack/react-query": "^5.96.2",
    "@types/multer": "^2.1.0",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "mermaid": "^11.14.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "vscode-jsonrpc": "^8.2.1",
    "web-push": "^3.6.7",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "@github/copilot": "1.0.54"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260518.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "patch-package": "^8.0.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.3"
  }
}
