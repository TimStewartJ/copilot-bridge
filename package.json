  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/timstewartj/copilot-bridge.git"
  },
  "homepage": "https://github.com/timstewartj/copilot-bridge#readme",
  "type": "module",
  "scripts": {
    "dev": "npx tsx src/launcher.ts",
    "dev:server": "npx tsx src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
