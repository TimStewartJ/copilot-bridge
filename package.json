{
  "name": "copilot-teams-bridge",
  "version": "0.1.0",
  "description": "Bridge between Teams and Copilot CLI via MCP + SDK",
  "type": "module",
  "scripts": {
    "dev": "npx tsx src/launcher.ts",
    "dev:server": "npx tsx src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@github/copilot-sdk": "0.2.0",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "node-cron": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.1"
  }
}
